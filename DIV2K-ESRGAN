 # Gaussian Blur\n    \"blur_1\": apply_gaussian_blur(img, 1),\n    \"blur_3\": apply_gaussian_blur(img, 3),\n\n    # Motion Blur\n    \"motion_5\": apply_motion_blur(img, 5),\n    \"motion_15\": apply_motion_blur(img, 15),\n}\n\nprint(f\"Created {len(noise_versions)} noisy versions.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T21:50:29.128436Z","iopub.execute_input":"2026-05-20T21:50:29.129007Z","iopub.status.idle":"2026-05-20T21:50:30.941207Z","shell.execute_reply.started":"2026-05-20T21:50:29.128978Z","shell.execute_reply":"2026-05-20T21:50:30.940337Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# ESRGAN ROBUSTNESS TESTING\n# ============================================================\n\nnetG.eval()\n\nresults = []\n\nplt.figure(figsize=(18, 60))\n\nidx = 1\n\nfor name, noisy in noise_versions.items():\n\n    # ========================================================\n    # Create LR Image\n    # ========================================================\n\n    lr = cv2.resize(\n        noisy,\n        (img.shape[1] // 4, img.shape[0] // 4),\n        interpolation=cv2.INTER_CUBIC\n    )\n\n    # ========================================================\n    # Convert To Tensor\n    # ========================================================\n\n    lr_tensor = torch.from_numpy(lr).float() / 255.0\n\n    lr_tensor = lr_tensor.permute(2,0,1).unsqueeze(0).to(device)\n\n    # ========================================================\n    # Inference\n    # ========================================================\n\n    with torch.no_grad():\n\n        sr = netG(lr_tensor).clamp(0,1)\n\n    # ========================================================\n    # Convert Back To Image\n    # ========================================================\n\n    sr_img = sr.squeeze(0).permute(1,2,0).cpu().numpy()\n\n    sr_img = (sr_img * 255).astype(np.uint8)\n\n    # ========================================================\n    # Metrics\n    # ========================================================\n\n    psnr = compare_psnr(img, sr_img, data_range=255)\n\n    ssim = compare_ssim(\n        img,\n        sr_img,\n        channel_axis=2,\n        data_range=255\n    )\n\n    results.append({\n        \"noise\": name,\n        \"psnr\": psnr,\n        \"ssim\": ssim\n    })\n\n    # ========================================================\n    # Visualization\n    # ========================================================\n\n    plt.subplot(len(noise_versions), 3, idx)\n\n    plt.imshow(img)\n\n    plt.title(\"Original\")\n\n    plt.axis(\"off\")\n\n\n    plt.subplot(len(noise_versions), 3, idx + 1)\n\n    plt.imshow(noisy)\n\n    plt.title(name)\n\n    plt.axis(\"off\")\n\n\n    plt.subplot(len(noise_versions), 3, idx + 2)\n\n    plt.imshow(sr_img)\n\n    plt.title(\n        f\"Enhanced\\nPSNR={psnr:.2f}\\nSSIM={ssim:.4f}\"\n    )\n\n    plt.axis(\"off\")\n\n    idx += 3\n\nplt.tight_layout()\n\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T21:50:30.942519Z","iopub.execute_input":"2026-05-20T21:50:30.943370Z","iopub.status.idle":"2026-05-20T21:51:10.063884Z","shell.execute_reply.started":"2026-05-20T21:50:30.943346Z","shell.execute_reply":"2026-05-20T21:51:10.063018Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# RESULTS TABLE\n# ============================================================\n\nimport pandas as pd\n\ndf_results = pd.DataFrame(results)\n\ndf_results = df_results.sort_values(\n    by=\"psnr\",\n    ascending=False\n)\n\ndisplay(df_results)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T21:43:21.897343Z","iopub.execute_input":"2026-05-20T21:43:21.897843Z","iopub.status.idle":"2026-05-20T21:43:22.214230Z","shell.execute_reply.started":"2026-05-20T21:43:21.897813Z","shell.execute_reply":"2026-05-20T21:43:22.213412Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# SAVE ENHANCED IMAGES\n# ============================================================\n\nSAVE_DIR = \"robustness_results\"\n\nos.makedirs(SAVE_DIR, exist_ok=True)\n\nnetG.eval()\n\nfor name, noisy in noise_versions.items():\n\n    # Create LR\n    lr = cv2.resize(\n        noisy,\n        (img.shape[1] // 4, img.shape[0] // 4),\n        interpolation=cv2.INTER_CUBIC\n    )\n\n    # Tensor\n    lr_tensor = torch.from_numpy(lr).float() / 255.0\n\n    lr_tensor = lr_tensor.permute(2,0,1).unsqueeze(0).to(device)\n\n    # Inference\n    with torch.no_grad():\n\n        sr = netG(lr_tensor).clamp(0,1)\n\n    # Convert back\n    sr_img = sr.squeeze(0).permute(1,2,0).cpu().numpy()\n\n    sr_img = (sr_img * 255).astype(np.uint8)\n\n    # Save\n    Image.fromarray(sr_img).save(\n        os.path.join(SAVE_DIR, f\"{name}.png\")\n    )\n\nprint(\"All enhanced images saved.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T21:43:24.883594Z","iopub.execute_input":"2026-05-20T21:43:24.884440Z","iopub.status.idle":"2026-05-20T21:43:50.689239Z","shell.execute_reply.started":"2026-05-20T21:43:24.884413Z","shell.execute_reply":"2026-05-20T21:43:50.688317Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# SAVE FINAL GENERATOR FOR UI / INFERENCE\n# ============================================================\n\nimport torch\nimport os\n\nSAVE_PATH = \"realesrgan_generator_only.pth\"\n\n# لو DataParallel شغال\ngenerator = netG.module if hasattr(netG, \"module\") else netG\n\ntorch.save(generator.state_dict(), SAVE_PATH)\n\nprint(f\"Generator saved to: {SAVE_PATH}\")\nprint(f\"File size: {os.path.getsize(SAVE_PATH)/1e6:.2f} MB\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T22:05:14.708148Z","iopub.execute_input":"2026-05-20T22:05:14.708957Z","iopub.status.idle":"2026-05-20T22:05:14.798030Z","shell.execute_reply.started":"2026-05-20T22:05:14.708923Z","shell.execute_reply":"2026-05-20T22:05:14.797342Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Summary\n\n**Real-ESRGAN** implementation trained on DIV2K (800 train / 100 valid) with:\n\n### Architecture\n| Component | Specification |\n|-----------|--------------|\n| Generator | RRDBNet, 23 RRDB blocks, 64 channels, residual scaling 0.2 |\n| Attention | ChannelAttention (Squeeze-and-Excitation) after RRDB trunk |\n| Discriminator | U-Net with Spectral Normalization, skip connections |\n\n### Degradation Pipeline (Real-ESRGAN high-order)\n- Gaussian blur (random σ ∈ [0.1, 3.0]) · Additive Gaussian noise · JPEG compression\n- Random interpolation (bicubic / bilinear / nearest) · Two-stage stochastic pipeline\n\n### Loss Functions\n| Loss | Weight | Description |\n|------|--------|-------------|\n| L1 | 1.0 | Pixel-wise absolute difference |\n| VGG Perceptual | 1.0 | 5-layer VGG19 (relu1\\_2 → relu5\\_4) weighted L1 |\n| RaGAN | 0.005 | Relativistic average GAN with softplus |\n| FFT Frequency | 0.1 | Amplitude + phase in Fourier domain |\n| LPIPS | 0.5 | Normalised VGG feature matching |\n\n### Training\n- Mixed precision (AMP) · EMA (decay 0.999) · TTUR (lr\\_G=1e‑4, lr\\_D=2e‑4)\n- Adam optimisers · CosineAnnealingWarmRestarts · Gradient clipping (1.0)\n- Patch-based random crops (128×128) · Automatic GPU detection + DataParallel\n\n### Checkpoints\n- Full state saved every `save_every` epochs · Best model tracked by PSNR\n- Single-file generator export for inference · Resume from latest checkpoint\n\n---\n\n**Output:** 4× super-resolution robust to real-world degradations (noise, blur, JPEG).\n","metadata":{}}]}