================================\n# Implements realistic degradations:\n#   • Gaussian blur (random kernel + sigma)\n#   • Additive Gaussian noise\n#   • JPEG compression\n#   • Random resizing (bicubic / bilinear / nearest)\n#   • Applied randomly per sample in a high-order pipeline\n\n\ndef gaussian_kernel_2d(k_size: int, sigma: float, device='cpu'):\n    \"\"\"Create a 2D Gaussian kernel.\"\"\"\n    coords = torch.arange(k_size, dtype=torch.float32, device=device) - k_size // 2\n    g = torch.exp(-(coords ** 2) / (2 * sigma ** 2 + 1e-8))\n    g /= g.sum()\n    return g[:, None] @ g[None, :]\n\n\ndef sinc_kernel_2d(k_size: int, cutoff: float, device='cpu'):\n    \"\"\"Create a 2D sinc (Lanczos-like) kernel.\"\"\"\n    coords = torch.arange(k_size, dtype=torch.float32, device=device) - k_size // 2\n    coords = coords + 1e-8\n    g = torch.sin(cutoff * math.pi * coords) / (math.pi * coords)\n    g /= g.sum()\n    return g[:, None] @ g[None, :]\n\n\ndef apply_gaussian_blur(img_tensor: torch.Tensor,\n                         sigma_range=(0.1, 3.0)) -> torch.Tensor:\n    \"\"\"Apply random Gaussian blur to a BxCxHxW tensor.\"\"\"\n    sigma = random.uniform(*sigma_range)\n    k = int(2 * math.ceil(3 * sigma) + 1)\n    if k % 2 == 0:\n        k += 1\n    if k < 3 or k > 21:\n        return img_tensor\n    kernel = gaussian_kernel_2d(k, sigma, img_tensor.device)\n    kernel = kernel[None, None, :, :].repeat(3, 1, 1, 1)\n    pad = k // 2\n    return F.conv2d(F.pad(img_tensor, [pad] * 4, mode='replicate'), kernel, groups=3)\n\n\ndef apply_noise(img_tensor: torch.Tensor,\n                 sigma_range=(1.0 / 255.0, 30.0 / 255.0)) -> torch.Tensor:\n    \"\"\"Add random Gaussian noise.\"\"\"\n    sigma = random.uniform(*sigma_range)\n    return img_tensor + torch.randn_like(img_tensor) * sigma\n\n\ndef apply_jpeg_compress(img_pil: Image.Image,\n                         quality_range=(30, 95)) -> Image.Image:\n    \"\"\"Apply JPEG compression via PIL.\"\"\"\n    quality = random.randint(*quality_range)\n    buf = io.BytesIO()\n    img_pil.save(buf, format='JPEG', quality=quality, optimize=False)\n    buf.seek(0)\n    return Image.open(buf).convert('RGB')\n\n\ndef apply_random_resize(img_tensor: torch.Tensor,\n                         scale_factor: float) -> torch.Tensor:\n    \"\"\"Downscale with random interpolation mode.\"\"\"\n    mode = random.choice(['bicubic', 'bilinear', 'nearest'])\n    kwargs = dict(mode=mode, scale_factor=scale_factor)\n    if mode == 'nearest':\n        kwargs['antialias'] = False\n    else:\n        kwargs['align_corners'] = False\n        kwargs['antialias'] = True\n    return F.interpolate(img_tensor, **kwargs)\n\n\ndef high_order_degrade(hr_pil: Image.Image,\n                        final_scale: int = 4) -> Image.Image:\n    \"\"\"\n    Real-ESRGAN high-order degradation pipeline.\n\n    Pipeline structure (applied stochastically):\n      Order 1: blur -> downsample (2x) -> noise -> JPEG\n      Order 2: blur -> downsample (2x) -> noise -> JPEG\n      Total downsampling: ~4x\n\n    Each step is applied with configurable probability.\n    \"\"\"\n    hr_tensor = TF.to_tensor(hr_pil).unsqueeze(0)  # [1, 3, H, W]\n\n    # ── Order 1 ──\n    if random.random() < 0.8:\n        hr_tensor = apply_gaussian_blur(hr_tensor)\n\n    hr_tensor = apply_random_resize(hr_tensor, 0.5)\n\n    if random.random() < 0.5:\n        hr_tensor = apply_noise(hr_tensor)\n\n    # Convert to PIL for JPEG\n    lr_pil = TF.to_pil_image(hr_tensor.squeeze(0).clamp(0, 1))\n    if random.random() < 0.5:\n        lr_pil = apply_jpeg_compress(lr_pil)\n\n    # ── Order 2 (with lower probability) ──\n    if random.random() < 0.3:\n        lr_tensor = TF.to_tensor(lr_pil).unsqueeze(0)\n        if random.random() < 0.5:\n            lr_tensor = apply_gaussian_blur(lr_tensor, sigma_range=(0.1, 1.5))\n\n        # Determine remaining downsampling factor\n        lr_tensor = apply_random_resize(lr_tensor, 1.0 / (final_scale / 2))\n\n        if random.random() < 0.5:\n            lr_tensor = apply_noise(lr_tensor)\n\n        lr_pil = TF.to_pil_image(lr_tensor.squeeze(0).clamp(0, 1))\n        if random.random() < 0.3:\n            lr_pil = apply_jpeg_compress(lr_pil, quality_range=(50, 95))\n\n    # Ensure final LR size matches expected\n    lr_tensor = TF.to_tensor(lr_pil).unsqueeze(0)\n    expected_lr_size = hr_pil.size[0] // final_scale, hr_pil.size[1] // final_scale\n    if lr_tensor.shape[-2:] != (expected_lr_size[1], expected_lr_size[0]):\n        lr_tensor = F.interpolate(\n            lr_tensor, size=(expected_lr_size[1], expected_lr_size[0]),\n            mode='bicubic', align_corners=False\n        )\n\n    return TF.to_pil_image(lr_tensor.squeeze(0).clamp(0, 1))\n\n\nprint('Degradation pipeline ready.')\nprint('  • Gaussian blur (sigma ∈ [0.1, 3.0])')\nprint('  • Gaussian noise (sigma ∈ [1/255, 30/255])')\nprint('  • JPEG compression (quality ∈ [30, 95])')\nprint('  • Random resize (bicubic / bilinear / nearest)')\nprint('  • High-order (2-stage) stochastic pipeline')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:46.308770Z","iopub.execute_input":"2026-05-20T17:51:46.309039Z","iopub.status.idle":"2026-05-20T17:51:46.326021Z","shell.execute_reply.started":"2026-05-20T17:51:46.309020Z","shell.execute_reply":"2026-05-20T17:51:46.325155Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 5. DATASET CLASS\n# ============================================================\n\nclass DIV2KDataset(Dataset):\n    \"\"\"DIV2K dataset with on-the-fly degradation.\n\n    Loads HR images, applies random crops, and generates LR\n    via the degradation pipeline (or bicubic for validation).\n    \"\"\"\n\n    def __init__(self, hr_dir: str, hr_size: int = 128,\n                 scale: int = 4, degrade: bool = True):\n        self.paths = sorted(\n            glob.glob(os.path.join(hr_dir, '*.png')) +\n            glob.glob(os.path.join(hr_dir, '*.jpg')) +\n            glob.glob(os.path.join(hr_dir, '*.jpeg'))\n        )\n        self.hr_size = hr_size\n        self.lr_size = hr_size // scale\n        self.scale = scale\n        self.degrade = degrade\n\n        if len(self.paths) == 0:\n            raise FileNotFoundError(f'No images found in {hr_dir}')\n\n        print(f'  Loaded {len(self.paths)} images from {hr_dir}')\n\n    def __len__(self):\n        return len(self.paths)\n\n    def __getitem__(self, idx):\n        hr_pil = Image.open(self.paths[idx]).convert('RGB')\n\n        # Random crop\n        i, j, h, w = transforms.RandomCrop.get_params(hr_pil, (self.hr_size, self.hr_size))\n        hr_crop = TF.crop(hr_pil, i, j, h, w)\n\n        # Generate LR\n        if self.degrade:\n            lr_pil = high_order_degrade(hr_crop, self.scale)\n            lr = TF.to_tensor(lr_pil)\n        else:\n            lr = TF.resize(\n                hr_crop, (self.lr_size, self.lr_size),\n                transforms.InterpolationMode.BICUBIC\n            )\n            lr = TF.to_tensor(lr)\n\n        hr = TF.to_tensor(hr_crop)\n\n        # Random horizontal / vertical flip (augmentation)\n        if random.random() > 0.5:\n            lr = TF.hflip(lr)\n            hr = TF.hflip(hr)\n        if random.random() > 0.5:\n            lr = TF.vflip(lr)\n            hr = TF.vflip(hr)\n\n        return lr, hr\n\n\n# ── Load datasets ─────────────────────────────────────────────────────\nprint('\\nLoading datasets...')\ntry:\n    train_dataset = DIV2KDataset(cfg.train_hr_dir, cfg.hr_size, cfg.scale, degrade=True)\nexcept FileNotFoundError as e:\n    print(f'Error: {e}')\n    print('Please check the Kaggle dataset paths in Config.')\n    raise\n\nvalid_dataset = DIV2KDataset(cfg.valid_hr_dir, cfg.hr_size, cfg.scale, degrade=False)\n\ntrain_loader = DataLoader(\n    train_dataset,\n    batch_size=cfg.batch_size,\n    shuffle=True,\n    num_workers=cfg.num_workers,\n    pin_memory=True,\n    drop_last=True,\n    prefetch_factor=2 if cfg.num_workers > 0 else None,\n)\n\nvalid_loader = DataLoader(\n    valid_dataset,\n    batch_size=cfg.batch_size,\n    shuffle=False,\n    num_workers=cfg.num_workers,\n    pin_memory=True,\n    drop_last=False,\n)\n\nprint(f'\\nTrain batches/epoch: {len(train_loader)}')\nprint(f'Valid batches/epoch: {len(valid_loader)}')\n\n# Quick data sanity check\nlr_sample, hr_sample = next(iter(train_loader))\nprint(f'\\nSample batch shapes — LR: {list(lr_sample.shape)}, HR: {list(hr_sample.shape)}')\nprint(f'LR range: [{lr_sample.min():.4f}, {lr_sample.max():.4f}]')\nprint(f'HR range: [{hr_sample.min():.4f}, {hr_sample.max():.4f}]')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:46.326916Z","iopub.execute_input":"2026-05-20T17:51:46.327183Z","iopub.status.idle":"2026-05-20T17:51:52.462915Z","shell.execute_reply.started":"2026-05-20T17:51:46.327154Z","shell.execute_reply":"2026-05-20T17:51:52.462079Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 6. GENERATOR — RRDBNet  (23 blocks, attention, residual scaling)\n# ============================================================\n\n\nclass ChannelAttention(nn.Module):\n    \"\"\"Squeeze-and-Excitation channel attention block.\"\"\"\n\n    def __init__(self, channels: int, reduction: int = 16):\n        super().__init__()\n        self.pool = nn.AdaptiveAvgPool2d(1)\n        self.fc = nn.Sequential(\n            nn.Conv2d(channels, channels // reduction, 1, bias=False),\n            nn.ReLU(inplace=True),\n            nn.Conv2d(channels // reduction, channels, 1, bias=False),  # was: nn.Conv2d(channels, channels, 1, bias=False),\n            nn.Sigmoid(),\n        )\n\n    def forward(self, x):\n        return x * self.fc(self.pool(x))\n\n\nclass SpatialAttention(nn.Module):\n    \"\"\"Spatial attention block using convolution.\"\"\"\n\n    def __init__(self, kernel_size: int = 7):\n        super().__init__()\n        padding = kernel_size // 2\n        self.conv = nn.Conv2d(2, 1, kernel_size, padding=padding, bias=False)\n        self.sigmoid = nn.Sigmoid()\n\n    def forward(self, x):\n        avg_out = torch.mean(x, dim=1, keepdim=True)\n        max_out, _ = torch.max(x, dim=1, keepdim=True)\n        attn = torch.cat([avg_out, max_out], dim=1)\n        attn = self.sigmoid(self.conv(attn))\n        return x * attn\n\n\nclass DenseBlock(nn.Module):\n    \"\"\"Dense block with 3 convs and residual scaling.\"\"\"\n\n    def __init__(self, nf: int = 64, grow: int = 32, res_scale: float = 0.2):\n        super().__init__()\n        self.rs = res_scale\n        self.c1 = nn.Conv2d(nf, grow, 3, 1, 1)\n        self.c2 = nn.Conv2d(nf + grow, grow, 3, 1, 1)\n        self.c3 = nn.Conv2d(nf + 2 * grow, nf, 3, 1, 1)\n        self.lrelu = nn.LeakyReLU(0.2, inplace=True)\n\n    def forward(self, x):\n        x1 = self.lrelu(self.c1(x))\n        x2 = self.lrelu(self.c2(torch.cat([x, x1], 1)))\n        x3 = self.c3(torch.cat([x, x1, x2], 1))\n        return x + x3 * self.rs\n\n\nclass RRDB(nn.Module):\n    \"\"\"Residual-in-Residual Dense Block with residual scaling.\"\"\"\n\n    def __init__(self, nf: int = 64, res_scale: float = 0.2):\n        super().__init__()\n        self.rs = res_scale\n        self.b1 = DenseBlock(nf, res_scale=res_scale)\n        self.b2 = DenseBlock(nf, res_scale=res_scale)\n        self.b3 = DenseBlock(nf, res_scale=res_scale)\n\n    def forward(self, x):\n        return x + self.b3(self.b2(self.b1(x))) * self.rs\n\n\nclass Generator(nn.Module):\n    \"\"\"RRDBNet generator with optional channel/spatial attention.\n\n    Architecture:\n      Conv(3→nf) → [RRDB × num_blocks] → Conv → Upsample(×4) → Conv(→3)\n\n    Args:\n        nf: Number of base feature channels (default: 64)\n        num_blocks: Number of RRDB blocks (default: 23)\n        scale: Upscaling factor (default: 4)\n        use_attention: Add channel attention after trunk\n    \"\"\"\n\n    def __init__(self, nf: int = 64, num_blocks: int = 23,\n                 scale: int = 4, use_attention: bool = True):\n        super().__init__()\n\n        # Initial convolution\n        self.conv_first = nn.Conv2d(3, nf, 3, 1, 1)\n\n        # RRDB trunk\n        trunk = [RRDB(nf, res_scale=0.2) for _ in range(num_blocks)]\n        self.trunk = nn.Sequential(*trunk)\n\n        # Post-trunk convolution\n        self.conv_trunk = nn.Conv2d(nf, nf, 3, 1, 1)\n\n        # Optional attention\n        self.use_attention = use_attention\n        if use_attention:\n            self.attention = ChannelAttention(nf, reduction=16)\n\n        # Upsampling (×4 via two ×2 PixelShuffle steps)\n        ups = []\n        for _ in range(scale // 2):\n            ups += [\n                nn.Conv2d(nf, nf * 4, 3, 1, 1),\n                nn.PixelShuffle(2),\n                nn.LeakyReLU(0.2, inplace=True),\n            ]\n        self.upsampler = nn.Sequential(*ups)\n\n        # Output convolution\n        self.conv_last = nn.Conv2d(nf, 3, 3, 1, 1)\n\n        # Initialisation\n        self._init_weights()\n\n    def _init_weights(self):\n        for m in self.modules():\n            if isinstance(m, nn.Conv2d):\n                nn.init.kaiming_normal_(m.weight, mode='fan_in', nonlinearity='relu')\n                if m.bias is not None:\n                    nn.init.zeros_(m.bias)\n\n    def forward(self, x):\n        f = self.conv_first(x)\n        trunk_out = self.trunk(f)\n        trunk_out = self.conv_trunk(trunk_out)\n\n        # Residual (global skip)\n        h = trunk_out + f\n\n        if self.use_attention:\n            h = self.attention(h)\n\n        h = self.upsampler(h)\n        return self.conv_last(h)\n\n\n# ── Instantiate ───────────────────────────────────────────────────────\nnetG = Generator(\n    nf=cfg.nf,\n    num_blocks=cfg.num_rrdb,\n    scale=cfg.scale,\n    use_attention=True,\n)\n\ng_params = sum(p.numel() for p in netG.parameters() if p.requires_grad)\nprint(f'Generator: {g_params:,} trainable parameters')\nprint(f'  RRDB blocks: {cfg.num_rrdb}')\nprint(f'  Base channels: {cfg.nf}')\nprint(f'  Attention: ChannelAttention')\n\nif NUM_GPUS > 1:\n    netG = nn.DataParallel(netG)\nnetG = netG.to(device)\nprint(f'Generator moved to {device}')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:52.464282Z","iopub.execute_input":"2026-05-20T17:51:52.464765Z","iopub.status.idle":"2026-05-20T17:51:52.665047Z","shell.execute_reply.started":"2026-05-20T17:51:52.464734Z","shell.execute_reply":"2026-05-20T17:51:52.664313Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 7. DISCRIMINATOR — U-Net with Spectral Normalization\n# ============================================================\n# U-Net style discriminator provides pixel-level feedback via\n# spatial output maps (PatchGAN). Spectral norm stabilises training.\n\n\nclass UNetDiscriminator(nn.Module):\n    \"\"\"U-Net discriminator with spectral norm and skip connections.\n\n    Architecture:\n      Encoder: Conv→[Conv↓2×4]→[Conv↓2×8]→[Conv↓2×16]→[Conv↓2×16]\n      Decoder: UpConv→Cat(skip)→Conv→...→Conv(→1)\n\n    Output: Single-channel spatial score map (size = input / 4)\n    \"\"\"\n\n    def __init__(self, nf: int = 64):\n        super().__init__()\n        self.lrelu = nn.LeakyReLU(0.2, inplace=True)\n\n        # Encoder\n        self.e0 = spectral_norm(nn.Conv2d(3, nf, 3, 1, 1))           # 3 → 64\n        self.e1 = spectral_norm(nn.Conv2d(nf, nf * 2, 4, 2, 1))      # 64 → 128\n        self.e2 = spectral_norm(nn.Conv2d(nf * 2, nf * 4, 4, 2, 1))  # 128 → 256\n        self.e3 = spectral_norm(nn.Conv2d(nf * 4, nf * 8, 4, 2, 1))  # 256 → 512\n        self.e4 = spectral_norm(nn.Conv2d(nf * 8, nf * 8, 4, 2, 1))  # 512 → 512\n\n        # Decoder\n        self.d3 = spectral_norm(nn.Conv2d(nf * 8 + nf * 8, nf * 8, 3, 1, 1))      # cat e4+e3\n        self.d2 = spectral_norm(nn.Conv2d(nf * 8 + nf * 4, nf * 4, 3, 1, 1))      # cat d3+e2\n        self.d1 = spectral_norm(nn.Conv2d(nf * 4 + nf * 2, nf * 2, 3, 1, 1))      # cat d2+e1\n        self.d0 = spectral_norm(nn.Conv2d(nf * 2 + nf, nf, 3, 1, 1))             # cat d1+e0\n\n        self.out = spectral_norm(nn.Conv2d(nf, 1, 3, 1, 1))\n\n    def forward(self, x):\n        # ── Encoder (with skips) ──\n        e0 = self.lrelu(self.e0(x))              # B, 64, H, W\n        e1 = self.lrelu(self.e1(e0))             # B, 128, H/2, W/2\n        e2 = self.lrelu(self.e2(e1))             # B, 256, H/4, W/4\n        e3 = self.lrelu(self.e3(e2))             # B, 512, H/8, W/8\n        e4 = self.lrelu(self.e4(e3))             # B, 512, H/16, W/16\n\n        # ── Decoder (with skip connections) ──\n        d3 = F.interpolate(e4, scale_factor=2, mode='bilinear', align_corners=False)\n        d3 = self.lrelu(self.d3(torch.cat([d3, e3], dim=1)))          # B, 512, H/8, W/8\n\n        d2 = F.interpolate(d3, scale_factor=2, mode='bilinear', align_corners=False)\n        d2 = self.lrelu(self.d2(torch.cat([d2, e2], dim=1)))          # B, 256, H/4, W/4\n\n        d1 = F.interpolate(d2, scale_factor=2, mode='bilinear', align_corners=False)\n        d1 = self.lrelu(self.d1(torch.cat([d1, e1], dim=1)))          # B, 128, H/2, W/2\n\n        d0 = F.interpolate(d1, scale_factor=2, mode='bilinear', align_corners=False)\n        d0 = self.lrelu(self.d0(torch.cat([d0, e0], dim=1)))          # B, 64, H, W\n\n        return self.out(d0)  # B, 1, H, W\n\n\n# ── Instantiate ───────────────────────────────────────────────────────\nnetD = UNetDiscriminator(nf=cfg.disc_nf)\n\nd_params = sum(p.numel() for p in netD.parameters() if p.requires_grad)\nprint(f'Discriminator (U-Net): {d_params:,} trainable parameters')\nprint(f'  Base channels: {cfg.disc_nf}')\nprint(f'  Spectral norm: Enabled')\nprint(f'  Output: Spatial patch scores')\n\nif NUM_GPUS > 1:\n    netD = nn.DataParallel(netD)\nnetD = netD.to(device)\nprint(f'Discriminator moved to {device}')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:52.666005Z","iopub.execute_input":"2026-05-20T17:51:52.666327Z","iopub.status.idle":"2026-05-20T17:51:52.710579Z","shell.execute_reply.started":"2026-05-20T17:51:52.666305Z","shell.execute_reply":"2026-05-20T17:51:52.709964Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 8. LOSS FUNCTIONS\n# ============================================================\n\ncriterion_l1 = nn.L1Loss()\n\n# ── VGG19 Perceptual Loss ────────────────────────────────────────────\nVGG_LAYER_WEIGHTS = [1.0 / 2.6, 1.0 / 4.8, 1.0 / 3.7, 1.0 / 5.6, 1.0 / 0.8]\n\nclass VGGPerceptualLoss(nn.Module):\n    def __init__(self):\n        super().__init__()\n        vgg = vgg19(weights=VGG19_Weights.IMAGENET1K_V1).features\n        self.blocks = nn.ModuleList([\n            nn.Sequential(*list(vgg.children())[:2]),\n            nn.Sequential(*list(vgg.children())[2:7]),\n            nn.Sequential(*list(vgg.children())[7:12]),\n            nn.Sequential(*list(vgg.children())[12:21]),\n            nn.Sequential(*list(vgg.children())[21:30]),\n        ])\n        for p in self.parameters():\n            p.requires_grad = False\n        self.weights = VGG_LAYER_WEIGHTS\n        self.register_buffer('mean', torch.tensor([0.485, 0.456, 0.406]).view(1, 3, 1, 1))\n        self.register_buffer('std',  torch.tensor([0.229, 0.224, 0.225]).view(1, 3, 1, 1))\n\n    def forward(self, sr, hr):\n        sr = (sr - self.mean) / self.std\n        hr = (hr - self.mean) / self.std\n        loss = 0.0\n        x_sr, x_hr = sr, hr\n        for idx, block in enumerate(self.blocks):\n            x_sr = block(x_sr)\n            x_hr = block(x_hr)\n            loss += self.weights[idx] * F.l1_loss(x_sr, x_hr.detach())\n        return loss\n\ncriterion_perc = VGGPerceptualLoss().to(device)\n\n# ── Relativistic Average GAN (RaGAN) ────────────────────────────────\ndef ragan_loss(d_real, d_fake):\n    e_real = d_real.mean(dim=(2, 3), keepdim=True)\n    e_fake = d_fake.mean(dim=(2, 3), keepdim=True)\n    d_loss = (F.softplus(-(d_real - e_fake)) + F.softplus(d_fake - e_real)).mean()\n    g_adv = (F.softplus(-(d_fake - e_real)) + F.softplus(d_real - e_fake)).mean()\n    return d_loss, g_adv\n\n# ── FFT Frequency Loss (stable version) ─────────────────────────────\nclass FrequencyLoss(nn.Module):\n    def __init__(self, amp_weight=0.1):\n        super().__init__()\n        self.amp_w = amp_weight\n\n    def forward(self, sr, hr):\n        sr_fft = torch.fft.rfft2(sr)\n        hr_fft = torch.fft.rfft2(hr)\n        sr_mag = torch.abs(sr_fft) + 1e-8\n        hr_mag = torch.abs(hr_fft) + 1e-8\n        return self.amp_w * F.smooth_l1_loss(sr_mag, hr_mag)\n\ncriterion_freq = FrequencyLoss().to(device)\n\n# ── LPIPS Perceptual Loss (simplified) ──────────────────────────────\nclass LPIPSLoss(nn.Module):\n    def __init__(self):\n        super().__init__()\n        vgg = vgg19(weights=VGG19_Weights.IMAGENET1K_V1).features\n        self.blocks = nn.ModuleList([\n            nn.Sequential(*list(vgg.children())[:2]),\n            nn.Sequential(*list(vgg.children())[2:7]),\n            nn.Sequential(*list(vgg.children())[7:12]),\n            nn.Sequential(*list(vgg.children())[12:21]),\n            nn.Sequential(*list(vgg.children())[21:30]),\n        ])\n        for p in self.parameters():\n            p.requires_grad = False\n        self.register_buffer('mean', torch.tensor([0.485, 0.456, 0.406]).view(1, 3, 1, 1))\n        self.register_buffer('std',  torch.tensor([0.229, 0.224, 0.225]).view(1, 3, 1, 1))\n\n    def forward(self, sr, hr):\n        sr = (sr - self.mean) / self.std\n        hr = (hr - self.mean) / self.std\n        loss = 0.0\n        x_sr, x_hr = sr, hr\n        for block in self.blocks:\n            x_sr = block(x_sr)\n            x_hr = block(x_hr)\n            norm_sr = x_sr / (torch.norm(x_sr, dim=1, keepdim=True) + 1e-10)\n            norm_hr = x_hr / (torch.norm(x_hr, dim=1, keepdim=True) + 1e-10)\n            loss += F.l1_loss(norm_sr, norm_hr.detach())\n        return loss\n\ncriterion_lpips = LPIPSLoss().to(device)\n\nprint('\\nLoss functions initialised:')\nprint('  • L1 (pixel)')\nprint('  • VGG19 perceptual (5 layers, weighted)')\nprint('  • RaGAN (relativistic, softplus)')\nprint('  • FFT frequency (amplitude only, rfft2, smooth_l1)')\nprint('  • LPIPS (normalised VGG features)')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:52.711458Z","iopub.execute_input":"2026-05-20T17:51:52.711817Z","iopub.status.idle":"2026-05-20T17:51:58.594072Z","shell.execute_reply.started":"2026-05-20T17:51:52.711794Z","shell.execute_reply":"2026-05-20T17:51:58.593091Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 9. EXPONENTIAL MOVING AVERAGE (EMA)\n# ============================================================\n# Maintains smoothed weights for the generator.\n# EMA weights are used for inference and validation.\n\n\nclass EMA:\n    \"\"\"Exponential Moving Average for generator weights.\n\n    Usage:\n        ema = EMA(model, decay=0.999)\n        # After each G step:\n        ema.update()\n        # Before validation / inference:\n        ema.apply()\n        # After validation:\n        ema.restore()\n    \"\"\"\n\n    def __init__(self, model: nn.Module, decay: float = 0.999):\n        self.model = model\n        self.decay = decay\n        self.shadow = {\n            n: p.data.clone()\n            for n, p in model.named_parameters()\n            if p.requires_grad\n        }\n        self.backup = {}\n        self.num_updates = 0\n\n    def update(self):\n        \"\"\"Update shadow weights with warmup ramp on effective decay.\"\"\"\n        self.num_updates += 1\n        # Ramp from ~0.1 → decay over the first ~1000 steps to avoid\n        # cold-start: early validation otherwise uses ~80% random-init weights.\n        effective_decay = min(self.decay, (1 + self.num_updates) / (10 + self.num_updates))\n        for n, p in self.model.named_parameters():\n            if p.requires_grad:\n                self.shadow[n].data = (\n                    effective_decay * self.shadow[n].data +\n                    (1 - effective_decay) * p.data\n                )\n\n    def apply(self):\n        \"\"\"Copy shadow weights to model (for evaluation).\"\"\"\n        self.backup = {}\n        for n, p in self.model.named_parameters():\n            if p.requires_grad:\n                self.backup[n] = p.data.clone()\n                p.data = self.shadow[n].data\n\n    def restore(self):\n        \"\"\"Restore original model weights from backup.\"\"\"\n        for n, p in self.model.named_parameters():\n            if p.requires_grad and n in self.backup:\n                p.data = self.backup[n].data\n\n    def state_dict(self):\n        return {'shadow': self.shadow, 'decay': self.decay, 'num_updates': self.num_updates}\n\n    def load_state_dict(self, state):\n        self.decay = state['decay']\n        self.shadow = state['shadow']\n        self.num_updates = state.get('num_updates', 0)\n\n\n# Wrap the raw (non-DataParallel) model for EMA\nema_g = netG.module if NUM_GPUS > 1 else netG\nema = EMA(ema_g, decay=cfg.ema_decay)\nprint(f'EMA initialised (decay = {cfg.ema_decay})')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:58.595291Z","iopub.execute_input":"2026-05-20T17:51:58.595821Z","iopub.status.idle":"2026-05-20T17:51:58.618436Z","shell.execute_reply.started":"2026-05-20T17:51:58.595795Z","shell.execute_reply":"2026-05-20T17:51:58.617850Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# 10. METRICS — PSNR, SSIM, LPIPS\n# ============================================================\n\n\n@torch.no_grad()\ndef compute_psnr_ssim(netG: nn.Module, loader: DataLoader,\n                       device: torch.device,\n                       max_batches: Optional[int] = None):\n    \"\"\"Compute PSNR (dB) and SSIM over a dataset.\n\n    Uses EMA weights internally (caller should apply/restore EMA).\n    \"\"\"\n    netG.eval()\n    psnr_vals, ssim_vals = [], []\n\n    for i, (lr, hr) in enumerate(loader):\n        if max_batches is not None and i >= max_batches:\n            break\n\n        lr, hr = lr.to(device), hr.to(device)\n        sr = netG(lr).clamp(0, 1)\n\n        for j in range(hr.size(0)):\n            sr_np = (sr[j].cpu().numpy().transpose(1, 2, 0) * 255).astype(np.uint8)\n            hr_np = (hr[j].cpu().numpy().transpose(1, 2, 0) * 255).astype(np.uint8)\n\n            psnr_vals.append(ski_psnr(hr_np, sr_np, data_range=255))\n            ssim_vals.append(ski_ssim(hr_np, sr_np, channel_axis=2, data_range=255))\n\n    return float(np.mean(psnr_vals)), float(np.mean(ssim_vals))\n\n\n@torch.no_grad()\ndef compute_lpips_score(netG: nn.Module, loader: DataLoader,\n                         device: torch.device,\n                         lpips_fn: nn.Module,\n                         max_batches: Optional[int] = None):\n    \"\"\"Compute LPIPS score (lower = better perceptual similarity).\"\"\"\n    netG.eval()\n    lpips_fn.eval()\n    scores = []\n\n    for i, (lr, hr) in enumerate(loader):\n        if max_batches is not None and i >= max_batches:\n            break\n\n        lr, hr = lr.to(device), hr.to(device)\n        sr = netG(lr).clamp(0, 1)\n\n        # LPIPS expects normalised inputs; our LPIPSLoss handles normalisation internally\n        l = lpips_fn(sr, hr)\n        scores.append(l.item())\n\n    return float(np.mean(scores))\n\n\nprint('Metrics ready: PSNR, SSIM, LPIPS')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T17:51:58.620259Z","iopub.execute_input":"2026-