 ============================================================\n\ndef add_gaussian_noise(img, sigma=25):\n\n    noise = np.random.normal(0, sigma, img.shape)\n\n    noisy = img.astype(np.float32) + noise\n\n    return np.clip(noisy, 0, 255).astype(np.uint8)\n\n\ndef add_salt_pepper(img, amount=0.05):\n\n    noisy = img.copy()\n\n    num_salt = np.ceil(amount * img.size * 0.5)\n\n    coords = [\n        np.random.randint(0, i - 1, int(num_salt))\n        for i in img.shape[:2]\n    ]\n\n    noisy[coords[0], coords[1]] = 255\n\n    num_pepper = np.ceil(amount * img.size * 0.5)\n\n    coords = [\n        np.random.randint(0, i - 1, int(num_pepper))\n        for i in img.shape[:2]\n    ]\n\n    noisy[coords[0], coords[1]] = 0\n\n    return noisy\n\n\ndef add_speckle_noise(img, intensity=0.2):\n\n    noise = np.random.randn(*img.shape) * intensity\n\n    noisy = img.astype(np.float32) + img.astype(np.float32) * noise\n\n    return np.clip(noisy, 0, 255).astype(np.uint8)\n\n\ndef apply_jpeg_compression(img, quality=30):\n\n    encode_param = [int(cv2.IMWRITE_JPEG_QUALITY), quality]\n\n    _, encimg = cv2.imencode('.jpg', img, encode_param)\n\n    decimg = cv2.imdecode(encimg, 1)\n\n    return cv2.cvtColor(decimg, cv2.COLOR_BGR2RGB)\n\n\ndef apply_gaussian_blur(img, sigma=2):\n\n    ksize = int(sigma * 3) * 2 + 1\n\n    return cv2.GaussianBlur(img, (ksize, ksize), sigma)\n\n\ndef apply_motion_blur(img, kernel_size=9):\n\n    kernel = np.zeros((kernel_size, kernel_size))\n\n    kernel[int((kernel_size - 1) / 2), :] = np.ones(kernel_size)\n\n    kernel = kernel / kernel_size\n\n    blurred = cv2.filter2D(img, -1, kernel)\n\n    return blurred","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-20T21:35:52.000520Z","iopub.execute_input":"2026-05-20T21:35:52.001248Z","iopub.status.idle":"2026-05-20T21:35:52.013311Z","shell.execute_reply.started":"2026-05-20T21:35:52.001207Z","shell.execute_reply":"2026-05-20T21:35:52.012320Z"}},"outputs":[],"execution_count":n